  (gr_text "(remember the CPU board switches!)" (at 87.757 168.91) (layer "F.SilkS") (tstamp becc86fc-98b5-41fb-ad3b-f216ca6a72db)
    (effects (font (size 1.5 1.5) (thickness 0.3) bold) (justify left bottom))
  )
  (gr_text "RAM is assumed to be 1 block from the\nupper address space down. \nValid configurations have no gaps and \nstart at the top. First 8k range ist \nthus fixed. Add more RAM by enabling \nthe additional regions but leave no gaps!" (at 150.241 144.907 90) (layer "F.SilkS") (tstamp ec2d1ada-df64-458d-b075-83d89baea294)
    (effects (font (size 1.5 1.5) (thickness 0.3) bold) (justify bottom))
  )

