  (gr_text "8k-16k" (at 117.2635 174.64) (layer "F.SilkS") (tstamp 96f095c8-77f6-4fcd-9471-8a2646adbf2c)
    (effects (font (size 2 2) (thickness 0.15)) (justify left bottom))
